# Environment: staging (default) or production
ENV="staging"

# Crossmint server-side API key for the project under test.
# The project needs the Treasury Wallets addon and a KYC config
# (addons.treasuryWallets=true and addons.kycConfig set; trustPolicy "crossmint" works).
CROSSMINT_API_KEY="sk_staging_your_server_api_key"

# Crossmint server-signer secret (format xmsk1_<64 hex>). Generate with:
#   deno task gen-secret
# The SDK derives the wallet address deterministically from this secret and signs
# locally; only the address is sent to Crossmint. Same secret => same wallet.
CROSSMINT_SIGNER_SECRET="xmsk1_your_64_hex_character_secret"

# Chain. Regulated transfers run on EVM; default is polygon-amoy (staging).
CHAIN="polygon-amoy"

# Token to transfer: a currency symbol (passed to wallet.send). The chain is taken
# from the wallet, so do NOT prefix it (use "usdc", not "polygon-amoy:usdc").
TOKEN="usdc"

# Treasury (source) wallet. Created/reused via this stable alias (locator COMPANY:<alias>).
# createWallet is idempotent on the alias, so the same alias resolves to the same
# treasury address on every run - fund that address once, then re-run freely.
TREASURY_ALIAS="payouts-treasury"

# Recipient: a user registered via the REST users API. The regulated transfer
# triggers the recipient's KYC + sanctions screen automatically.
RECIPIENT_EMAIL="recipient@example.com"
RECIPIENT_FIRST_NAME="Jane"
RECIPIENT_LAST_NAME="Doe"
RECIPIENT_DOB="1990-01-01"
RECIPIENT_COUNTRY="US"   # ISO 3166-1 alpha-2; must be a supported country (US, or a supported EU country)

# Transfer amount (decimal string). Use a small fraction so a funded treasury covers many test runs.
AMOUNT="0.1"
